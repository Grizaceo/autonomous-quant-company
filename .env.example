# AQTC runs safely in mock/paper mode by default.
AQTC_STRIPE_MODE=mock
AQTC_NVIDIA_MODE=mock
AQTC_LIVE_TRADING=false
AQTC_DAILY_BUDGET_USD=25
AQTC_REQUIRE_APPROVAL_ABOVE_USD=5
AQTC_REPORT_PRICE_USD=19
AQTC_DATA_PURCHASE_USD=2
AQTC_OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
AQTC_NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
AQTC_OPENCODE_ZEN_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Optional live/test integrations. The code also reads ~/.hermes/.env locally.
STRIPE_SECRET_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
OPENCODE_ZEN_API_KEY=
